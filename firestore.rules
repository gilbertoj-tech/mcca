rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /company/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /clients/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /contacts/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
